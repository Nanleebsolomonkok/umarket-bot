# ════════════════════════════════════════════════════════════════════════════
#  UMarket Bot — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to Git. This file (.env.example) is safe to commit.
# ════════════════════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────────────────────
# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your bot's Telegram username WITHOUT the @ (e.g. umarket_bot)
BOT_USERNAME=umarket_bot

# ── Admins ───────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that have admin access
# Add as many as you need, e.g. 6830221233,9876543210
ADMIN_IDS=6830221233

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get this from: Vercel Dashboard → Storage → Neon → Connect
# It looks like: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Paystack ─────────────────────────────────────────────────────────────────
# Your Paystack SECRET key (starts with sk_live_ or sk_test_)
# Get it from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# ── Webhook Security ──────────────────────────────────────────────────────────
# A random secret string used to verify that updates come from Telegram.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in Vercel env vars.
WEBHOOK_SECRET=generate_a_random_secret_here
